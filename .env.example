# ═══════════════════════════════════════════════════════
#  GoLinks — Environment Variables
# ═══════════════════════════════════════════════════════

# ─── Frontend ───────────────────────────────────────────
REACT_APP_API_URL=/api/v1
REACT_APP_BASE_URL=http://localhost:3000
REACT_APP_AUTH_IMAGE_URL=https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1920&q=80&auto=format&fit=crop
REACT_APP_ONBOARDING_IMAGE_URL=https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1920&q=80&auto=format&fit=crop
REACT_APP_INVITE_IMAGE_URL=https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1920&q=80&auto=format&fit=crop
REACT_APP_SIGNUP_IMAGE_URL=https://images.unsplash.com/photo-1497215728101-856f4ea42174?w=1920&q=80&auto=format&fit=crop

# ─── Docker (docker-compose.yml) ───────────────────────
POSTGRES_DB=golinks
POSTGRES_USER=golinks
POSTGRES_PASSWORD=golinks
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ─── Backend — Server ──────────────────────────────────
SERVER_PORT=8080

# ─── Backend — Database (PostgreSQL) ───────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/golinks
SPRING_DATASOURCE_USERNAME=golinks
SPRING_DATASOURCE_PASSWORD=golinks

# ─── Backend — RabbitMQ ────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT_TLS=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_SSL_ENABLED=false

# ─── Backend — Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend — OAuth2 (replace with real values) ───────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Backend — JWT ─────────────────────────────────────
JWT_KEYSTORE_PASSWORD=golinks123
JWT_KEY_PASSWORD=golinks123
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── Backend — CORS ────────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Backend — App Base URL (for email links) ─────────
APP_BASE_URL=http://localhost:3000

# ─── Backend — SMTP (leave empty to log to console) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@golinks.io
